# ==========================================
# STM32 AI Fault Tolerant Control Gateway
# Git Ignore Configuration
# ==========================================

# --- Workspace & IDE Specific ---
.metadata/
.plugins/
RemoteSystemsTempFiles/
*.log
.lock

# --- Build Output Logic (Strict Mode) ---
# Ignore everything inside any Debug or Release folder
**/Debug/*
**/Release/*

# Exceptions: Only keep HEX, LIST and MAKEFILE
!**/Debug/*.hex
!**/Debug/*.list
!**/Debug/makefile

# --- Source Code Protection (Global Ignores) ---
# Specifically block the junk files seen in image_e12221.png
*.cyclo
*.su
*.o
*.d
*.o.d
*.mk
*.elf
*.map
objects.list
objects.mk
sources.mk

# --- IDE Project Files ---
.settings/
.mxproject
*.launch

# --- OS Specific ---
.DS_Store
Thumbs.db